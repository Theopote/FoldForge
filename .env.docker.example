# Copy to `.env` in the repo root for `docker compose` (optional).
# All variables have defaults suitable for local demo.

# Protect /api and /storage (recommended for any shared host)
# FOLDFORGE_REQUIRE_API_AUTH=true
# FOLDFORGE_API_KEY=change-me

# AI generation (defaults to mock for offline demo)
AI_PROVIDER=mock
AI_ALLOW_PROVIDER_FALLBACK=false
# MESHY_API_KEY=
# REPLICATE_API_TOKEN=
# REPLICATE_TEXT_MODEL=
# REPLICATE_IMAGE_MODEL=
# TRIPOSR_REPLICATE_VERSION=
