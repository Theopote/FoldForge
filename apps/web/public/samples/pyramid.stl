solid pyramid
  facet normal 0 0 -1
    outer loop
      vertex -1 -1 0
      vertex 1 -1 0
      vertex 1 1 0
    endloop
  endfacet
  facet normal 0 0 -1
    outer loop
      vertex -1 -1 0
      vertex 1 1 0
      vertex -1 1 0
    endloop
  endfacet
  facet normal 0 -1 1
    outer loop
      vertex -1 -1 0
      vertex 1 -1 0
      vertex 0 0 1.6
    endloop
  endfacet
  facet normal 1 0 1
    outer loop
      vertex 1 -1 0
      vertex 1 1 0
      vertex 0 0 1.6
    endloop
  endfacet
  facet normal 0 1 1
    outer loop
      vertex 1 1 0
      vertex -1 1 0
      vertex 0 0 1.6
    endloop
  endfacet
  facet normal -1 0 1
    outer loop
      vertex -1 1 0
      vertex -1 -1 0
      vertex 0 0 1.6
    endloop
  endfacet
endsolid pyramid
