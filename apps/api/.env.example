# AI generation (Phase 2+)
# auto picks meshy > triposr > replicate > mock
AI_PROVIDER=auto
AI_ASYNC_FOR_MOCK=false

# Meshy — https://docs.meshy.ai
MESHY_API_KEY=
MESHY_POLL_INTERVAL_SEC=3
MESHY_POLL_TIMEOUT_SEC=600

# Replicate (TripoSR + custom models)
REPLICATE_API_TOKEN=
TRIPOSR_REPLICATE_VERSION=
REPLICATE_TEXT_MODEL=
REPLICATE_IMAGE_MODEL=

# CORS / debug
DEBUG=true
