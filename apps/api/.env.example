# AI generation (Phase 2+)
# auto picks meshy > triposr > replicate > mock
AI_PROVIDER=auto
AI_ASYNC_FOR_MOCK=false

# Meshy — https://docs.meshy.ai
MESHY_API_KEY=
MESHY_POLL_INTERVAL_SEC=3
MESHY_POLL_TIMEOUT_SEC=600

# Block PDF/SVG/ZIP export when unfold overlaps remain after auto-repair
BLOCK_EXPORT_ON_UNFOLD_OVERLAP=true

# Layout — exact NFP nesting above this piece count uses fast shelf packing
LAYOUT_NFP_MAX_PIECES=24
LAYOUT_NFP_MAX_STATIONARY=12

# Replicate (TripoSR + custom models)
REPLICATE_API_TOKEN=
TRIPOSR_REPLICATE_VERSION=
REPLICATE_TEXT_MODEL=
REPLICATE_IMAGE_MODEL=

# CORS / debug
DEBUG=true

# API authentication (production)
# When set, all /api/* and /storage/* routes require this key.
FOLDFORGE_API_KEY=
# Fail startup if auth is required but no key is configured
FOLDFORGE_REQUIRE_API_AUTH=false
