# FoldForge API
DEBUG=true

# Optional API auth
FOLDFORGE_REQUIRE_API_AUTH=false
FOLDFORGE_API_KEY=

# AI provider selection:
# - auto: use the first configured production provider, then mock
# - meshy: Meshy text/image-to-3D
# - replicate: generic Replicate text/image model versions
# - triposr: Replicate-hosted TripoSR image-to-3D
# - mock: offline procedural demo mode
AI_PROVIDER=auto
AI_ASYNC_FOR_MOCK=false
AI_ALLOW_PROVIDER_FALLBACK=false

# Meshy
MESHY_API_KEY=
MESHY_POLL_INTERVAL_SEC=3
MESHY_POLL_TIMEOUT_SEC=600

# Replicate generic providers
REPLICATE_API_TOKEN=
REPLICATE_TEXT_MODEL=
REPLICATE_IMAGE_MODEL=

# TripoSR via Replicate
TRIPOSR_REPLICATE_VERSION=

# Claude AI (instructions / prompt enhancer / seam advisor)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_INSTRUCTIONS_ENABLED=true
CLAUDE_PROMPT_ENHANCE_ENABLED=true
CLAUDE_SEAM_ADVISOR_ENABLED=false

# Paid AI generation rate limits (per API key, or per IP when auth is off)
AI_GENERATION_RATE_LIMIT_ENABLED=true
AI_GENERATION_RATE_LIMIT_PER_HOUR=12
AI_GENERATION_RATE_LIMIT_BURST=3
